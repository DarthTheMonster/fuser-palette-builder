{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FUSER Palette Builder",
  "version": "0.1.0",
  "identifier": "com.darth.fuser-palette-builder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "FUSER Palette Builder", "width": 1240, "height": 860, "resizable": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
